# RPiMonitor — Node Agent Environment Variables
# Copy to .env or set in systemd service file

# Bind address (0.0.0.0 listens on all interfaces)
PIMONITOR_HOST=0.0.0.0

# Listen port
PIMONITOR_PORT=8585

# Bearer token for API authentication (leave empty to disable auth)
PIMONITOR_TOKEN=

# Comma-separated list of systemd services to monitor
PIMONITOR_SERVICES=ssh,nginx,docker,ollama,mosquitto

# Dashboard auto-refresh interval in seconds
PIMONITOR_REFRESH=2

# Path to persist the service list across restarts
PIMONITOR_SERVICES_FILE=./services.json

# Flask debug mode (never enable in production)
PIMONITOR_DEBUG=false


# RPiMonitor Hub — additional variables (hub only)

PIHUB_HOST=0.0.0.0
PIHUB_PORT=8686
PIHUB_TOKEN=
PIHUB_POLL_INTERVAL=5
PIHUB_TIMEOUT=4
PIHUB_DISCOVERY_PORT=8585
PIHUB_NODES_FILE=./hub_nodes.json
PIHUB_DEBUG=false
